classDiagram
    %% ============================================================
    %% CORE CLASSES (IMPLEMENTED)
    %% ============================================================

    class Owner {
        %% Unique identifier and contact info
        -id: string
        -name: string
        -email: string
        -phoneNumber: string
        %% Time constraint for daily planning
        -availableHoursPerDay: float

        %% Pet management
        +addPet(pet: Pet)
        +getPets()

        %% Task management
        +addTask(task: Task)
        +editTask(taskId: string, updates: dict)
        +deleteTask(taskId: string)
        +getTasks()

        %% Scheduling
        +getAvailableHours()
    }

    class Pet {
        %% Basic pet information
        -id: string
        -name: string
        -type: string
        -age: int
        -gender: string
        -color: string

        %% Task retrieval
        +getTasks()
        +getTasksForDay(date: string)
    }

    class Task {
        %% Task identification and metadata
        -id: string
        -name: string
        -category: string
        -petId: string

        %% Scheduling parameters
        -duration: int
        -priority: string
        -frequency: string

        %% Task behavior
        +isRecurring()
        +canFitInTimeSlot(startTime, endTime)
        +getEstimatedEndTime(startTime)
    }

    class DailyPlan {
        %% Plan metadata
        -date: string
        -owner: Owner

        %% Schedule data
        -scheduledTasks: Task[]
        -totalTimeAvailable: float
        -totalTimeUsed: float

        %% Schedule generation and manipulation
        +generateSchedule(tasks: Task[], availableHours: float)
        +sortTasksByPriority()
        +fitTasksInAvailableTime()

        %% Plan output and explanation
        +getFormattedPlan()
        +explainSchedule()
        +canAddTask(task: Task)
    }

    %% ============================================================
    %% CORE RELATIONSHIPS
    %% ============================================================
    Owner "1" --> "*" Pet : owns
    Owner "1" --> "*" Task : creates/manages
    Pet "1" --> "*" Task : has
    DailyPlan "1" --> "1" Owner : plans for
    DailyPlan "1" --> "*" Task : contains

